    "title": "1N: EEG Mirror",
    "client": "MuLabs × 204",
    "cat": "interactive",
    "year": "2025",
    "runtime": "—",
    "note": "Real-time brain activity becomes a living artwork. Neurofeedback-driven Magic Mirror, London.",
